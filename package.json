{
  "name": "life-quest-journal",
  "version": "1.1.2",
  "description": "Transform your life goals into epic quests. Track habits, earn rewards, and level up your life!",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "copy:web": "node scripts/copy-web.js",
    "cap:sync": "npm run copy:web && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:build": "npm run copy:web && npx cap sync android && npx cap open android"
  },
  "keywords": [
    "productivity",
    "goals",
    "tasks",
    "habits"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "build": {
    "appId": "com.lifequestjournal.app",
    "productName": "Life Quest Journal",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    }
  },
  "dependencies": {
    "@capacitor-community/in-app-review": "^8.0.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2"
  }
}
